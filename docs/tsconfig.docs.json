{
	"extends": "@deviltea/tsconfig/browser",
	"compilerOptions": {
		"composite": true
	},
	"include": [
		"./**/*",
		"./.vitepress/theme"
	],
	"exclude": [
		"./.vitepress/cache",
		"./.vitepress/dist",
		"./.vitepress/config.ts"
	],
	"vueCompilerOptions": {
		"vitePressExtensions": [
			".md"
		]
	}
}
